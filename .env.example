POSTGRES_DB=hostelhub
POSTGRES_USER=postgres
# Set either POSTGRES_PASSWORD or POSTGRES_PASSWORD_FILE before deployment
POSTGRES_PASSWORD=
POSTGRES_PASSWORD_FILE=
POSTGRES_PORT=5432

API_PORT=8080
WEB_PORT=4200

# Set either JWT_SECRET or JWT_SECRET_FILE. JWT secrets must be 32+ chars and non-placeholder.
JWT_SECRET=
JWT_SECRET_FILE=
CORS_ALLOWED_ORIGINS=http://localhost:4200
FRONTEND_URL=http://localhost:4200
EXPOSE_DEV_RESET_URL=false
JAVA_OPTS=-Xms256m -Xmx768m
